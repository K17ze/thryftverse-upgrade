# Thryftverse Production Environment
# Copy to .env.production and fill all required values.
# Do not commit real secrets.

# ---- Runtime ----
NODE_ENV=production
API_PORT=4000
EXPO_PUBLIC_API_BASE_URL=https://api.thryftverse.app
EXPO_PUBLIC_ENABLE_RUNTIME_MOCKS=false
API_ENABLE_MOCK_WEBHOOKS=false

# ---- Core Data ----
POSTGRES_USER=thryftverse
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=thryftverse
DATABASE_REPLICA_URL=
REDIS_URL=redis://redis:6379

# ---- Object Storage ----
MINIO_ROOT_USER=minio_service_user
MINIO_ROOT_PASSWORD=replace_with_strong_password
S3_BUCKET=thryftverse-media
S3_REGION=eu-west-1
S3_PUBLIC_ENDPOINT=https://cdn.thryftverse.app

# ---- Key Service ----
KEY_SERVICE_REGION=eu-west
KEY_SERVICE_COUNTRY=NL
KEY_SERVICE_MASTER_KEY_B64=replace_with_base64_32byte_key
KEY_SERVICE_CLIENT_TOKEN=replace_with_long_random_token
KEY_SERVICE_ADMIN_TOKEN=replace_with_long_random_token

# ---- API Security/Auth ----
API_SECURITY_ADMIN_TOKEN=replace_with_long_random_token
AUTH_ACCESS_TOKEN_SECRET=replace_with_long_random_secret
AUTH_REFRESH_TOKEN_SECRET=replace_with_long_random_secret
AUTH_EMAIL_PROVIDER=resend
AUTH_EMAIL_FROM=noreply@thryftverse.app
RESEND_API_KEY=re_xxx

# ---- OAuth ----
GOOGLE_OAUTH_CLIENT_IDS=google_android_id,google_ios_id,google_web_id
APPLE_OAUTH_AUDIENCE=com.thryftverse.app

# ---- Compliance / KYC ----
KYC_DEFAULT_VENDOR=persona
KYC_VERIFICATION_BASE_URL=https://verify.thryftverse.app/session

# ---- Payments (configure at least one provider set) ----
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
WISE_API_KEY=
WISE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Shipping (optional live providers) ----
EASYSHIP_API_KEY=
EASYSHIP_API_BASE_URL=https://public-api.easyship.com/2024-09
EASYSHIP_WEBHOOK_SECRET=

# ---- Observability ----
SENTRY_DSN=https://examplePublicKey@self-hosted-sentry.example/1
SENTRY_TRACES_SAMPLE_RATE=0.15
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_HTTP_URL=http://otel-collector:4318/v1/traces

# ---- Notifications ----
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
PUSH_DEFAULT_CHANNEL=default

# ---- 1ze ----
ONEZE_ATTESTATION_SIGNING_SECRET=replace_with_long_random_secret

# ---- Optional tuning ----
AUCTION_SWEEP_INTERVAL_MS=30000
