# Thryftverse — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── API ──────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ── Google OAuth ─────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=your-google-android-client-id
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=your-google-web-client-id
GOOGLE_OAUTH_CLIENT_IDS=your-android-client-id,your-ios-client-id,your-web-client-id

# ── Apple OAuth ──────────────────────────────────────────
APPLE_OAUTH_AUDIENCE=com.thryftverse.app

# ── Stripe ───────────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# ── Wise ─────────────────────────────────────────────────
WISE_API_KEY=your-wise-api-key
WISE_WEBHOOK_SECRET=your-wise-webhook-secret

# ── Runtime ──────────────────────────────────────────────
# Set to 'true' to enable mock data in non-dev environments
# EXPO_PUBLIC_ENABLE_RUNTIME_MOCKS=false
