{
  "name": "thryftverse",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api ml-service key-service postgres redis minio",
    "docker:check": "node backend/scripts/docker-smoke-check.mjs",
    "typecheck": "tsc --noEmit",
    "lint:design-tokens": "node scripts/check-design-tokens.mjs",
    "check": "npm run typecheck",
    "check:animated-scroll": "node scripts/check-animated-scroll-usage.mjs",
    "doctor": "npx expo-doctor",
    "test": "vitest run --dir src",
    "test:watch": "vitest --dir src",
    "test:smoke": "vitest run src/__tests__/smoke-flows.test.ts",
    "verify:phase": "npm run typecheck && npm run check:animated-scroll && vitest run src/__tests__/premium-form-primitives.test.ts src/__tests__/screen-import-smoke.test.ts src/__tests__/animated-scroll-usage.test.ts src/__tests__/coOwnTruthRules.test.ts src/__tests__/profileMediaTruth.test.ts src/__tests__/flagshipComponentsApplied.test.ts src/__tests__/ui20CoOwnFinancialTruth.test.ts src/__tests__/ui21DeviceAudit.test.ts src/__tests__/ui22ExploreElevation.test.ts src/__tests__/ui22MessagingElevation.test.ts src/__tests__/ui22ClosetElevation.test.ts",
    "i18n:extract": "node scripts/extract-i18n-strings.mjs",
    "deploy:prod:validate": "node scripts/validate-production-env.mjs .env.production",
    "docker:up:prod": "docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:down:prod": "docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml down",
    "docker:logs:prod": "docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml logs -f api ml-service key-service",
    "staging:shipping-ops": "node backend/scripts/staging-shipping-ops-rehearsal.mjs",
    "launch:phase8": "node backend/scripts/phase8-launch-ops.mjs --strict",
    "launch:phase8:full": "node backend/scripts/phase8-launch-ops.mjs --strict --run-rehearsal",
    "launch:phase8:cleanup:dry": "node backend/scripts/phase8-launch-ops.mjs --cleanup-db",
    "launch:phase8:cleanup:apply": "node backend/scripts/phase8-launch-ops.mjs --cleanup-db --confirm-db-cleanup"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/stack": "^7.8.6",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.0",
    "expo-apple-authentication": "~55.0.13",
    "expo-asset": "~55.0.17",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.19",
    "expo-clipboard": "~55.0.13",
    "expo-dev-client": "~55.0.35",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-media-library": "~55.0.17",
    "expo-modules-core": "~55.0.25",
    "expo-network": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-video": "~55.0.17",
    "expo-web-browser": "~55.0.16",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "tslib": "^2.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "babel-preset-expo": "~55.0.8",
    "eslint-plugin-react-hooks": "^5.1.0-beta-26f2496093-20240514",
    "expo-doctor": "^1.19.10",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  },
  "private": true
}
