# Backend API Production Environment
# Copy to backend/api/.env.production for direct API deployments.

NODE_ENV=production
PORT=4000
APP_URL=https://api.thryftverse.app
DATABASE_URL=postgresql://thryftverse:replace_with_strong_password@postgres:5432/thryftverse
DATABASE_REPLICA_URL=
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=35000
REDIS_URL=redis://redis:6379

KEY_SERVICE_URL=http://key-service:4100
KEY_SERVICE_CLIENT_TOKEN=replace_with_long_random_token
KEY_SERVICE_ADMIN_TOKEN=replace_with_long_random_token

S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://cdn.thryftverse.app
S3_REGION=eu-west-1
S3_ACCESS_KEY=minio_service_user
S3_SECRET_KEY=replace_with_strong_password
S3_BUCKET=thryftverse-media
S3_FORCE_PATH_STYLE=true
S3_CDN_BASE_URL=https://cdn.thryftverse.app
S3_MAX_IMAGE_UPLOAD_BYTES=20971520
S3_MAX_VIDEO_UPLOAD_BYTES=104857600
S3_MAX_DOCUMENT_UPLOAD_BYTES=10485760
S3_PRESIGN_TTL_SECONDS=600
S3_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,image/heic,image/heif,video/mp4,video/quicktime,video/x-m4v,application/pdf

# Deterministic decision baselines. This is not presented as trained ML.
DECISION_SERVICE_URL=http://ml-service:8000

AUTH_ACCESS_TOKEN_SECRET=replace_with_long_random_secret
AUTH_REFRESH_TOKEN_SECRET=replace_with_long_random_secret
AUTH_EMAIL_PROVIDER=resend
AUTH_EMAIL_FROM=noreply@thryftverse.app
RESEND_API_KEY=re_xxx

# AI chat agents (secret; backend only)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AGENT_DEFAULT_MODEL=gpt-5.6-terra
OPENAI_AGENT_MAX_OUTPUT_TOKENS=900
OPENAI_AGENT_TIMEOUT_MS=30000

API_SECURITY_ADMIN_TOKEN=replace_with_long_random_token
API_ENABLE_MOCK_WEBHOOKS=false
API_RATE_LIMIT_MAX=140
API_RATE_LIMIT_WINDOW=1 minute

KYC_DEFAULT_VENDOR=stripe_identity
KYC_RETURN_URL=https://thryftverse.app/compliance/kyc-complete
KYC_WEBHOOK_SECRET=whsec_xxx

GOOGLE_OAUTH_CLIENT_IDS=google_android_id,google_ios_id,google_web_id
APPLE_OAUTH_AUDIENCE=com.thryftverse.app

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
WISE_API_KEY=
WISE_WEBHOOK_SECRET=
WISE_API_BASE_URL=https://api.wise.com
WISE_PLATFORM_PROFILE_ID=
WISE_PLATFORM_RECIPIENT_ACCOUNT_ID=
WISE_PLATFORM_TRANSFER_REFERENCE_PREFIX=THRYFTVERSE SWEEP
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
EVRI_API_KEY=
EVRI_API_BASE_URL=
EVRI_WEBHOOK_SECRET=
DELHIVERY_API_KEY=
DELHIVERY_API_BASE_URL=
DELHIVERY_WEBHOOK_SECRET=
DHL_API_KEY=
DHL_API_BASE_URL=
DHL_WEBHOOK_SECRET=
ARAMEX_API_KEY=
ARAMEX_API_BASE_URL=
ARAMEX_WEBHOOK_SECRET=
EASYSHIP_API_KEY=
EASYSHIP_API_BASE_URL=https://public-api.easyship.com/2024-09
EASYSHIP_WEBHOOK_SECRET=
SHIPPING_FALLBACK_LABEL_BASE_URL=https://thryftverse.app/mock-shipping

DAILY_PAYOUT_VELOCITY_LIMIT_GBP=2000
PAYOUT_MANUAL_REVIEW_THRESHOLD_GBP=500
RECONCILIATION_SCHEDULE_UTC_HOUR=2
RECONCILIATION_MISMATCH_THRESHOLD_GBP=1
RECONCILIATION_CRITICAL_MISMATCH_THRESHOLD_GBP=10
OPS_ALERT_INTERVAL_MS=60000
PLATFORM_REVENUE_SWEEP_INTERVAL_MS=21600000
PLATFORM_REVENUE_SWEEP_GATEWAY=
PLATFORM_REVENUE_SWEEP_REQUIRE_EXTERNAL_TRANSFER=false
ALERTING_WEBHOOK_URLS=https://alerts.example.com/thryftverse-ops
ALERTING_ADMIN_USER_IDS=

SENTRY_DSN=https://examplePublicKey@self-hosted-sentry.example/1
SENTRY_TRACES_SAMPLE_RATE=0.15
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_HTTP_URL=http://otel-collector:4318/v1/traces

EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
PUSH_DEFAULT_CHANNEL=default

ONEZE_ATTESTATION_SIGNING_SECRET=replace_with_long_random_secret
ONEZE_SUPPLY_DRIFT_THRESHOLD_IZE=10
ONEZE_ENABLE_DIRECT_REDEMPTION=false
ONEZE_OPERATOR_TOKEN=
ONEZE_RESERVE_POLICY_ENABLED=true
ONEZE_RESERVE_RATIO_MIN=0.30
ONEZE_RESERVE_RATIO_MAX=0.60
ONEZE_OPERATIONAL_RESERVE_MG=
ONEZE_FX_SYNC_ENABLED=true
ONEZE_FX_SYNC_INTERVAL_MS=86400000
ONEZE_FX_PROVIDER_URL=https://api.exchangerate.host/latest
ONEZE_FX_PROVIDER_API_KEY=replace_with_live_fx_provider_key
ONEZE_FX_PROVIDER_BASE_CURRENCY=INR
ONEZE_AUTO_ADJUST_ENABLED=true
ONEZE_AUTO_ADJUST_INTERVAL_MS=3600000
ONEZE_AUTO_ADJUST_STEP_BPS=50
ONEZE_AUTO_ADJUST_LOOKBACK_HOURS=24
ONEZE_AUTO_ADJUST_HIGH_STRESS_THRESHOLD=0.85
ONEZE_AUTO_ADJUST_LOW_STRESS_THRESHOLD=0.35
ONEZE_AUTO_ADJUST_HIGH_REDEMPTION_RATE=0.80
ONEZE_AUTO_ADJUST_LOW_REDEMPTION_RATE=0.25
# Controlled 1ze anchor + country pricing is stored in DB migrations/admin endpoints.
# Do not configure GOLD_ORACLE_* in production for the controlled model.
