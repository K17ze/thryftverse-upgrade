# Thryftverse Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Core ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
DATABASE_URL=postgresql://thryftverse:thryftverse@localhost:5432/thryftverse
# DATABASE_REPLICA_URL=
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=35000
REDIS_URL=redis://localhost:6379

# ── Key Service ──────────────────────────────────────────
KEY_SERVICE_URL=http://localhost:4100
KEY_SERVICE_CLIENT_TOKEN=local-key-client-token
KEY_SERVICE_ADMIN_TOKEN=local-key-admin-token

# ── S3 / MinIO ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=thryftverse-media
S3_FORCE_PATH_STYLE=true
S3_CDN_BASE_URL=http://localhost:9000
S3_MAX_IMAGE_UPLOAD_BYTES=20971520
S3_MAX_VIDEO_UPLOAD_BYTES=104857600
S3_MAX_DOCUMENT_UPLOAD_BYTES=10485760
S3_PRESIGN_TTL_SECONDS=600
# S3_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,image/heic,image/heif,video/mp4,video/quicktime,video/x-m4v,application/pdf,text/plain

# ── ML Service ───────────────────────────────────────────
DECISION_SERVICE_URL=http://localhost:8000
# ML_SERVICE_URL remains accepted as a legacy alias.

# ── Auth ─────────────────────────────────────────────────
AUTH_ACCESS_TOKEN_SECRET=your-access-token-secret
AUTH_REFRESH_TOKEN_SECRET=your-refresh-token-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_HASH_COST=12
AUTH_EMAIL_PROVIDER=log
# AUTH_EMAIL_FROM=noreply@thryftverse.app
# RESEND_API_KEY=your-resend-api-key

# AI chat agents (server-side only)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_AGENT_DEFAULT_MODEL=gpt-5.6-terra
# OPENAI_AGENT_MAX_OUTPUT_TOKENS=900
# OPENAI_AGENT_TIMEOUT_MS=30000

# ── Google / Apple OAuth ─────────────────────────────────
# GOOGLE_OAUTH_CLIENT_IDS=your-android-client-id,your-ios-client-id,your-web-client-id
# APPLE_OAUTH_AUDIENCE=com.thryftverse.app

# ── Payment Providers ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# WISE_API_KEY=your-wise-api-key
# WISE_WEBHOOK_SECRET=your-wise-webhook-secret
# WISE_API_BASE_URL=https://api.wise.com
# WISE_PLATFORM_PROFILE_ID=
# WISE_PLATFORM_RECIPIENT_ACCOUNT_ID=
# WISE_PLATFORM_TRANSFER_REFERENCE_PREFIX=THRYFTVERSE SWEEP

# ── Shipping Providers (optional, falls back to static rates) ───────
# EVRI_API_KEY=
# EVRI_API_BASE_URL=https://api.evri.example
# EVRI_WEBHOOK_SECRET=
# DELHIVERY_API_KEY=
# DELHIVERY_API_BASE_URL=https://track.delhivery.example
# DELHIVERY_WEBHOOK_SECRET=
# DHL_API_KEY=
# DHL_API_BASE_URL=https://api.dhl.example
# DHL_WEBHOOK_SECRET=
# ARAMEX_API_KEY=
# ARAMEX_API_BASE_URL=https://api.aramex.example
# ARAMEX_WEBHOOK_SECRET=
SHIPPING_FALLBACK_LABEL_BASE_URL=https://thryftverse.app/mock-shipping

# ── Payout Safeguards / Reconciliation ───────────────────
DAILY_PAYOUT_VELOCITY_LIMIT_GBP=2000
PAYOUT_MANUAL_REVIEW_THRESHOLD_GBP=500
RECONCILIATION_SCHEDULE_UTC_HOUR=2
RECONCILIATION_MISMATCH_THRESHOLD_GBP=1
RECONCILIATION_CRITICAL_MISMATCH_THRESHOLD_GBP=10
OPS_ALERT_INTERVAL_MS=60000
PLATFORM_REVENUE_SWEEP_INTERVAL_MS=21600000
# Optional external transfer settings for platform revenue sweep.
# PLATFORM_REVENUE_SWEEP_GATEWAY=wise
# PLATFORM_REVENUE_SWEEP_REQUIRE_EXTERNAL_TRANSFER=false
# ALERTING_WEBHOOK_URLS=https://hooks.slack.com/services/xxx,https://discord.com/api/webhooks/xxx
# ALERTING_ADMIN_USER_IDS=admin_user_1,admin_user_2

# ── KYC ──────────────────────────────────────────────────
KYC_DEFAULT_VENDOR=stripe_identity
KYC_RETURN_URL=thryftverse://compliance/kyc-complete
# KYC_WEBHOOK_SECRET=whsec_xxx
# KYC_VERIFICATION_BASE_URL is a legacy development-only fallback and is not used by Stripe Identity.

# ── Security ─────────────────────────────────────────────
API_SECURITY_ADMIN_TOKEN=local-security-admin-token
API_RATE_LIMIT_MAX=140
API_RATE_LIMIT_WINDOW=1 minute

# ── Observability ────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.15
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_HTTP_URL=http://localhost:4318/v1/traces

# ── 1ze Controlled Monetary System ───────────────────────
# The controlled pricing engine uses DB-backed anchor + country policies.
# Gold oracle settings are deprecated and should stay unset.
ONEZE_SUPPLY_DRIFT_THRESHOLD_IZE=10
ONEZE_ENABLE_DIRECT_REDEMPTION=false
ONEZE_OPERATOR_TOKEN=local-security-admin-token
ONEZE_RESERVE_POLICY_ENABLED=false
ONEZE_RESERVE_RATIO_MIN=0.30
ONEZE_RESERVE_RATIO_MAX=0.60
# Source-of-truth operational reserve input from treasury/custody reports.
ONEZE_OPERATIONAL_RESERVE_MG=0
ONEZE_FX_SYNC_ENABLED=false
ONEZE_FX_SYNC_INTERVAL_MS=86400000
ONEZE_FX_PROVIDER_URL=https://api.exchangerate.host/latest
# ONEZE_FX_PROVIDER_API_KEY=
ONEZE_FX_PROVIDER_BASE_CURRENCY=INR
ONEZE_AUTO_ADJUST_ENABLED=false
ONEZE_AUTO_ADJUST_INTERVAL_MS=3600000
ONEZE_AUTO_ADJUST_STEP_BPS=50
ONEZE_AUTO_ADJUST_LOOKBACK_HOURS=24
ONEZE_AUTO_ADJUST_HIGH_STRESS_THRESHOLD=0.85
ONEZE_AUTO_ADJUST_LOW_STRESS_THRESHOLD=0.35
ONEZE_AUTO_ADJUST_HIGH_REDEMPTION_RATE=0.80
ONEZE_AUTO_ADJUST_LOW_REDEMPTION_RATE=0.25
ONEZE_ATTESTATION_SIGNING_SECRET=dev-only-oneze-attestation-signing-secret
