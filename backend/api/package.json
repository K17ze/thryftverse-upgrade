{
  "name": "thryftverse-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts",
    "backup:db": "node scripts/postgres-backup.mjs",
    "migrate": "tsx src/db/migrate.ts",
    "start": "node --enable-source-maps dist/index.js",
    "smoke:commerce": "node scripts/smoke-commerce-flow.mjs",
    "smoke:coown": "node scripts/smoke-coown-flow.mjs",
    "smoke:profile": "node scripts/smoke-profile-flow.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.882.0",
    "@aws-sdk/s3-request-presigner": "^3.882.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@mollie/api-client": "^4.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.47.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.7.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.6",
    "stripe": "^22.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
